# =========================================================================
# KOKORO MEDICAL BOT - CONFIGURATION TEMPLATE
# Copy this file to .env and fill in your details
# Command: cp .env.example .env
# =========================================================================

# --- LLM PROVIDER SELECTION ---
# Options: ollama, groq, openai
# If not specified, the system will auto-detect:
# - Use Groq if GROQ_API_KEY is present
# - Else, use OpenAI if OPENAI_API_KEY is present
# - Else, default to Ollama (100% Local)
LLM_PROVIDER=groq

# --- ⚡ Option 1: Groq Cloud LLM (Recommended for speed & Cloud Deploy) ---
# Get a free key at: https://console.groq.com/
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192

# --- 🍏 Option 2: OpenAI API (Alternative Cloud) ---
# Get key at: https://platform.openai.com/
OPENAI_API_KEY=sk-proj-your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# --- 🦙 Option 3: Ollama (100% Local LLM) ---
# Download Ollama at: https://ollama.com/
# Make sure to pull the model: ollama pull llama3
OLLAMA_MODEL=llama3
# Base URL for talking to Ollama.
# If running locally on host: http://localhost:11434
# If running in Docker talking to host: http://host.docker.internal:11434
# If running inside docker-compose using the Ollama service: http://ollama:11434
OLLAMA_BASE_URL=http://localhost:11434

# --- AWS CONFIGURATION (For DynamoDB History - Optional) ---
# Region where your resources are located (default: ap-south-1)
AWS_REGION=ap-south-1
CHAT_TABLE_NAME=ChatHistory

# Optional AWS Credentials (If not using IAM Instance Profiles/Roles)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
